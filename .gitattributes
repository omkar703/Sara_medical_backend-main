# Ensure shell scripts always use LF line endings on all platforms
*.sh text eol=lf

# Python files
*.py text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Markdown
*.md text eol=lf

# Windows-specific files keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# ============================================================================
# GOOGLE MEET CONFIGURATION - REAL CONSULTATION SCHEDULING
# ============================================================================
# To enable REAL Google Meet links instead of mock links, you need to:
#
# 1. Set up a Google Cloud Project
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Desktop application)
# 4. Generate a refresh token
# 5. Add the credentials below to your .env file
#
# Full setup guide: https://developers.google.com/calendar/api/quickstart/python
# ============================================================================

# Google OAuth 2.0 Credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Optional: Google Calendar ID (defaults to 'primary' - user's main calendar)
# GOOGLE_CALENDAR_ID=primary

# Enable real video calls feature
FEATURE_VIDEO_CALLS=true

# ============================================================================
# QUICK SETUP STEPS:
# ============================================================================
#
# Step 1: Create a Google Cloud Project
#   - Go to https://console.cloud.google.com/
#   - Create a new project
#   - Name it something like "Saramedico"
#
# Step 2: Enable Google Calendar API
#   - In the project, go to APIs & Services > Library
#   - Search for "Google Calendar API"
#   - Click "Enable"
#
# Step 3: Create OAuth 2.0 Credentials
#   - Go to APIs & Services > Credentials
#   - Click "Create Credentials" > "OAuth client ID"
#   - Choose "Desktop application"
#   - Download the JSON file
#   - Copy GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from the JSON
#
# Step 4: Generate Refresh Token
#   - Run this Python script (replace CLIENT_ID and CLIENT_SECRET):
#
#   from google_auth_oauthlib.flow import InstalledAppFlow
#   
#   SCOPES = [
#       'https://www.googleapis.com/auth/calendar.events',
#       'https://www.googleapis.com/auth/calendar.readonly',
#       'https://www.googleapis.com/auth/drive.readonly'
#   ]
#   
#   flow = InstalledAppFlow.from_client_secrets_file(
#       'credentials.json',  # Downloaded JSON from Step 3
#       SCOPES
#   )
#   creds = flow.run_local_server(port=0)
#   print(f"GOOGLE_REFRESH_TOKEN={creds.refresh_token}")
#
# Step 5: Add to .env
#   - Copy GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, and GOOGLE_REFRESH_TOKEN
#   - Add to your .env file
#   - Restart the backend
#
# Step 6: Test
#   - Schedule a consultation
#   - You should now get a real Google Meet link like:
#     https://meet.google.com/abc-defg-hij-klm
#
# ============================================================================
# TROUBLESHOOTING:
# ============================================================================
#
# If you still get mock links:
# 1. Check logs for "[Consultation Service] Using REAL Google Meet service"
# 2. Verify all three credentials are set in .env
# 3. Ensure FEATURE_VIDEO_CALLS=true in your .env
# 4. Restart the backend after changing .env
#
# If you get API errors:
# 1. Verify the refresh token is valid
# 2. Ensure Google Calendar API is enabled in Cloud Console
# 3. Check that doctor's email has Google Workspace access
#
# ============================================================================
